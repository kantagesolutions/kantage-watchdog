# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://watch.yourdomain.com
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

# ─── Admin login ──────────────────────────────────────────────────────────────
WATCHDOG_ADMIN_USERNAME=admin
WATCHDOG_ADMIN_PASSWORD=your_secure_password_here

# ─── Services to monitor ──────────────────────────────────────────────────────
HUB_URL=https://kantage.solutions
BUILDER_URL=https://builder.kantage.solutions
DEPLOY_URL=https://deploy.kantage.solutions

# ─── GitHub (for reading and writing code) ────────────────────────────────────
GITHUB_TOKEN=ghp_your_github_personal_access_token
GITHUB_ORG=your_github_org_or_username
HUB_REPO=kantage-hub
BUILDER_REPO=kantage-builder
DEPLOY_REPO=kantage-deploy

# ─── SSH (for direct server access) ──────────────────────────────────────────
HUB_SERVER_HOST=1.2.3.4
BUILDER_SERVER_HOST=1.2.3.5
DEPLOY_SERVER_HOST=1.2.3.6
SSH_USERNAME=root
# Paste your private key with newlines replaced by \n
WATCHDOG_SSH_KEY=-----BEGIN OPENSSH PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END OPENSSH PRIVATE KEY-----

# ─── AI (use at least one) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ─── Email alerts ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_gmail_app_password
ALERT_EMAIL=you@gmail.com
WATCHDOG_URL=https://watch.yourdomain.com

# ─── Cron security ────────────────────────────────────────────────────────────
CRON_SECRET=generate_with_openssl_rand_hex_32

# ─── Repair mode (set to false to disable auto-diagnosis when incident opens) ─
AUTO_REPAIR=true
